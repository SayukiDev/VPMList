# Default VPM repository manifest URL displayed on first visit.
# When VITE_ALLOW_URL_CHANGE is unset or "false", this is the only URL the
# UI will ever load.
VITE_DEFAULT_REPO_URL=https://vrchat-community.github.io/template-package-listing/index.json

# When set to "true", the UI lets visitors edit the URL bar and load any
# other VPM repository manifest (and supports `#/?url=...` shareable links).
# When unset or "false" (default), the URL bar is read-only and the only
# repository ever loaded is VITE_DEFAULT_REPO_URL.
VITE_ALLOW_URL_CHANGE=true

# Optional GitHub repository URL. When set, a GitHub icon link appears in
# the header. Leave unset to hide it.
# VITE_GITHUB_URL=https://github.com/your-name/your-repo
